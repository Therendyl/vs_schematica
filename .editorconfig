root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4
tab_width = 4

[*.json]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.{bat,cmd,ps1,md,yml,yaml}]
charset = utf-8-bom

[*.{xml,props,targets,csproj}]
indent_style = space
indent_size = 2

[*.{sln}]
charset = utf-8-bom
end_of_line = lf
